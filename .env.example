# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spikeclip?schema=public"

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API ───
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Auth ───
JWT_SECRET="change-me-in-production-to-a-random-string"

# ─── Storage ───
CLIPS_DIR="/tmp/spikeclip-clips"
CLIPS_BASE_URL="http://localhost:3001/api"

# ─── Sentry (optional) ───
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ─── Frontend ───
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
