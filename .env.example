# ─── Database ───
DATABASE_URL="postgresql://spikeclips:spikeclips_dev@localhost:5433/spikeclips?schema=public"

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=spikeclips_dev_redis

# ─── API ───
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
BACKEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000

# ─── Auth ───
JWT_SECRET="change-me-in-production-to-a-random-string"

# ─── Storage ───
STORAGE_DRIVER="local"
CLIPS_DIR="/tmp/spikeclips-clips"
CLIPS_BASE_URL="http://localhost:3001/api"
CLIP_SIGNING_SECRET="change-me-in-production-to-a-random-string"

# ─── MinIO (required when STORAGE_DRIVER=minio) ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=spikeclips-clips
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Workers ───
HEATMAP_WORKER_CONCURRENCY=5
CLIP_WORKER_CONCURRENCY=3
UV_THREADPOOL_SIZE=4

# ─── Sentry (optional) ───
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ─── OAuth ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Frontend ───
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="localhost"
