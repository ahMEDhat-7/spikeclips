# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spikeclips?schema=public"

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""

# ─── API ───
PORT=3001
FRONTEND_URL=https://spikeclips.com
NODE_ENV=production

# ─── Auth ───
JWT_SECRET="change-me-in-production-to-a-random-string"

# ─── Storage ───
STORAGE_DRIVER="local"
CLIPS_DIR="/tmp/spikeclips-clips"
CLIPS_BASE_URL="https://spikeclips.com/api"

# ─── MinIO (required when STORAGE_DRIVER=minio) ───
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=spikeclips-clips
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Workers ───
HEATMAP_WORKER_CONCURRENCY=5
CLIP_WORKER_CONCURRENCY=3
UV_THREADPOOL_SIZE=4

# ─── Sentry (optional) ───
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ─── Frontend ───
NEXT_PUBLIC_API_URL="https://spikeclips.com/api"
NEXT_PUBLIC_SITE_URL="https://spikeclips.com"
NEXT_PUBLIC_DOMAIN="spikeclips.com"
