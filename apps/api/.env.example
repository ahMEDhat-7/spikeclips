# === Core ===
DATABASE_URL=postgresql://spikeclips:spikeclips_dev@localhost:5433/spikeclips
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=spikeclips_dev_redis
PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# === Auth ===
JWT_SECRET=spikeclips-dev-jwt-secret-change-in-production

# === Storage ===
STORAGE_DRIVER=local
CLIPS_DIR=/tmp/spikeclips-clips
CLIPS_BASE_URL=http://localhost:3001/api
CLIP_SIGNING_SECRET=spikeclips-dev-signing-secret-change-in-production

# MinIO (only if STORAGE_DRIVER=minio)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=spikeclips-clips
MINIO_USE_SSL=false

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly
STRIPE_TEAM_MONTHLY_PRICE_ID=price_team_monthly
STRIPE_TEAM_YEARLY_PRICE_ID=price_team_yearly

# === OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Sentry (optional) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
